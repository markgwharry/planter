{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Soil Moisture — All Plants",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green",  "value": 40 },
              { "color": "blue",   "value": 90 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "thresholdsStyle": { "mode": "dashed" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"moisture\")\n  |> group(columns: [\"plant_id\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "title": "Current Moisture",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green",  "value": 40 },
              { "color": "blue",   "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true
      },
      "repeat": "plant",
      "repeatDirection": "h",
      "maxPerRow": 3,
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"moisture\")\n  |> filter(fn: (r) => r.plant_id == \"${plant}\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "title": "Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r.message_type == \"alert\")\n  |> filter(fn: (r) => r._field == \"moisture\" or r._field == \"status\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\", \"plant_id\", \"moisture\", \"status\"])\n  |> sort(columns: [\"_time\"], desc: true)\n  |> yield(name: \"alerts\")"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["planter", "iot"],
  "templating": {
    "list": [
      {
        "name": "plant",
        "type": "query",
        "datasource": { "type": "influxdb" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"moisture\", tag: \"plant_id\")",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] }
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Planter — Soil Moisture",
  "uid": "planter-moisture"
}
