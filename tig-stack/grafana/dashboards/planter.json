{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Soil Moisture — All Plants",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green",  "value": 40 },
              { "color": "blue",   "value": 90 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "pointSize": 6,
            "showPoints": "always",
            "thresholdsStyle": { "mode": "dashed" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"moisture\")\n  |> filter(fn: (r) => r.message_type == \"moisture\")\n  |> group(columns: [\"plant_id\"])\n  |> keep(columns: [\"_time\", \"_value\", \"plant_id\"])\n  |> rename(columns: {_value: \"moisture\"})\n  |> yield(name: \"raw\")"
        }
      ]
    },
    {
      "title": "Current Moisture",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green",  "value": 40 },
              { "color": "blue",   "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"moisture\")\n  |> filter(fn: (r) => r.message_type == \"moisture\")\n  |> group(columns: [\"plant_id\"])\n  |> last()\n  |> keep(columns: [\"_time\", \"_value\", \"plant_id\"])\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "title": "Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "influxdb", "uid": "" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_time" },
            "properties": [{ "id": "displayName", "value": "Time" }]
          },
          {
            "matcher": { "id": "byName", "options": "plant_id" },
            "properties": [{ "id": "displayName", "value": "Plant" }]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb" },
          "query": "from(bucket: \"moisture\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r.message_type == \"alert\")\n  |> filter(fn: (r) => r._field == \"moisture\")\n  |> keep(columns: [\"_time\", \"_value\", \"plant_id\"])\n  |> rename(columns: {_value: \"moisture\"})\n  |> sort(columns: [\"_time\"], desc: true)\n  |> yield(name: \"alerts\")"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["planter", "iot"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Planter — Soil Moisture",
  "uid": "planter-moisture"
